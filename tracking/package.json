{
  "name": "bookcars-tracking",
  "description": "Fleet tracking mobile app for BookCars",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "install:dependencies": "cd ../packages/currency-converter && npm i && cd ../bookcars-helper && npm i",
    "eas-build-pre-install": "npm run install:dependencies",
    "ts:build": "npm run install:dependencies && tsc --build --verbose",
    "ts:check": "npm run ts:build",
    "start": "npm run ts:build && expo start --port 8086",
    "start:clean": "npm run ts:build && expo start -c --port 8086",
    "android": "npm run ts:build && expo run:android",
    "ios": "npm run ts:build && expo run:ios",
    "lint": "eslint . --cache --cache-location .eslintcache",
    "fix": "eslint --fix .",
    "prebuild": "expo prebuild",
    "prebuild:clean": "expo prebuild --clean"
  },
  "dependencies": {
    "@babel/runtime": "^7.28.6",
    "@expo/metro-runtime": "^55.0.9",
    "@expo/vector-icons": "^15.1.1",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/datetimepicker": "8.6.0",
    "@react-navigation/native": "^7.1.28",
    "@react-navigation/native-stack": "^7.10.1",
    "axios": "^1.13.6",
    "axios-retry": "^4.5.0",
    "base-64": "^1.0.0",
    "date-fns": "^4.1.0",
    "expo": "55",
    "expo-constants": "~55.0.7",
    "expo-font": "~55.0.4",
    "expo-linking": "~55.0.7",
    "expo-localization": "~55.0.8",
    "expo-location": "~55.1.2",
    "expo-notifications": "~55.0.10",
    "expo-router": "~55.0.3",
    "expo-splash-screen": "~55.0.10",
    "expo-status-bar": "~55.0.4",
    "i18n-js": "^4.5.2",
    "lodash.debounce": "^4.0.8",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.2",
    "react-native-dotenv": "^3.4.11",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-maps": "1.27.2",
    "react-native-modal-datetime-picker": "^18.0.0",
    "react-native-paper": "^5.15.0",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-size-matters": "^0.4.2",
    "react-native-svg": "15.15.3",
    "react-native-toast-message": "^2.3.3",
    "react-native-vector-icons": "^10.3.0",
    "react-native-webview": "^13.16.1",
    "react-native-worklets": "0.7.2",
    "validator": "^13.15.26"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@types/base-64": "^1.0.2",
    "@types/lodash.debounce": "^4.0.9",
    "@types/react": "~19.2.14",
    "@types/react-native-dotenv": "^0.2.2",
    "@types/react-native-vector-icons": "^6.4.18",
    "@types/validator": "^13.15.10",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "babel-plugin-module-resolver": "^5.0.2",
    "babel-preset-expo": "~55.0.10",
    "cross-env": "^10.1.0",
    "eslint": "^9.39.2",
    "typescript": "~5.9.3"
  },
  "private": true
}
