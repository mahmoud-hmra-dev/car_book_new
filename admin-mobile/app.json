{
  "expo": {
    "jsEngine": "hermes",
    "name": "BookCars Admin",
    "version": "1.0.0",
    "scheme": "bookcars-admin",
    "slug": "bookcars-admin",
    "icon": "./assets/icon.png",
    "assetBundlePatterns": ["**/*"],
    "splash": {
      "backgroundColor": "#6B3CE6",
      "image": "./assets/splash.png"
    },
    "android": {
      "versionCode": 100,
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png"
      },
      "icon": "./assets/icon.png",
      "softwareKeyboardLayoutMode": "pan",
      "package": "com.bookcars.admin",
      "backgroundColor": "#00000000"
    },
    "ios": {
      "buildNumber": "1.0.0",
      "supportsTablet": true,
      "icon": "./assets/icon.png",
      "bundleIdentifier": "com.bookcars.admin"
    },
    "plugins": [
      "expo-localization",
      "./plugins/usesCleartextTraffic",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#6B3CE6",
          "image": "./assets/icon.png",
          "imageWidth": 200
        }
      ],
      [
        "expo-document-picker",
        {
          "iCloudContainerEnvironment": "Production"
        }
      ],
      "@react-native-google-signin/google-signin",
      "expo-apple-authentication",
      [
        "react-native-fbsdk-next",
        {
          "appID": "FACEBOOK_APP_ID",
          "clientToken": "FACEBOOK_CLIENT_TOKEN",
          "displayName": "BookCars Admin",
          "scheme": "FACEBOOK_SCHEME",
          "advertiserIDCollectionEnabled": false,
          "autoLogAppEventsEnabled": false,
          "isAutoInitEnabled": true
        }
      ],
      "expo-asset",
      "expo-font",
      "react-native-fbsdk-next",
      "@react-native-community/datetimepicker",
      "expo-router"
    ],
    "experiments": {
      "tsconfigPaths": true,
      "typedRoutes": true
    },
    "runtimeVersion": {
      "policy": "appVersion"
    }
  }
}
